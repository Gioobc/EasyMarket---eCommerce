{
  "expo": {
    "name": "EasyMarket",
    "slug": "easymarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "easymarket",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "imageWidth": 280,
      "resizeMode": "contain",
      "backgroundColor": "#052E1C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easymarket.app",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.easymarket.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#052E1C"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "@sentry/react-native/expo",
        {
          "organization": "ronceros-moviles",
          "project": "easymarket",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
